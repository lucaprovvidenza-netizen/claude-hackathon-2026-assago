<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Brennero Logistics - Portale Ordini</display-name>

    <!-- Filtro autenticazione -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.brennero.portal.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- La servlet. Una sola per tutto. -->
    <servlet>
        <servlet-name>PortalServlet</servlet-name>
        <servlet-class>com.brennero.portal.PortalServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>PortalServlet</servlet-name>
        <url-pattern>/portal</url-pattern>
    </servlet-mapping>

    <!-- Pagina di benvenuto -->
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <!-- Sessione: 30 minuti, come da "specifica" mai scritta -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
